# ==========================================
# SensorGuard Backend Environment Variables
# ==========================================

# ─── Server Configuration ───
# The port the Express server will listen on
PORT=3000

# ─── Database Configuration (Optional) ───
# MongoDB connection string for persisting alerts and history
MONGO_URI="mongodb://localhost:27017/sensorguard"

# ─── Security & Authentication ───
# JWT Secret for authenticating frontend users (admin login)
JWT_SECRET="development-jwt-secret-key-change-in-production"
# Hardware HMAC Secret Key used by ESP32 to sign MQTT payloads
HMAC_SECRET="sensorguard-hmac-secret-2025"

# ─── MQTT Broker Configuration ───
# URL of the Mosquitto MQTT broker for ESP32 hardware communication
MQTT_BROKER="mqtt://127.0.0.1:1883"
